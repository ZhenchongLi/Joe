{{- $pages := .Site.RegularPages }}
{{- range $pages.ByDate.Reverse }}
{{- if not .Draft }}
{{- $category := "Uncategorized" }}
{{- if .Params.categories }}
  {{- $category = index .Params.categories 0 }}
  {{- if eq $category "人工智能" }}{{ $category = "AI" }}{{ end }}
  {{- $category = title $category }}
{{- end }}

